{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ybooks",
  "version": "1.0.0",
  "identifier": "com.ybooks.desktop",
  "build": {
    "frontendDist": "../frontend",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Ybooks",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "url": "http://81.71.6.207:86/"
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "Ybooks 工作看板"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "© 2026 A+ Systems",
    "category": "Productivity",
    "shortDescription": "Ybooks 工作看板",
    "longDescription": "Ybooks — 高效工作管理桌面应用",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "autostart": {
      "macosExtraArgs": [],
      "linuxExtraArgs": []
    }
  }
}
